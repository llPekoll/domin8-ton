      { key: "blood-ground-middle2", start: 84, end: 93, frameRate: 15 },
      { key: "blood-from-left7", start: 95, end: 106, frameRate: 15 },
    ];

    bloodAnimations.forEach((anim) => {
      this.anims.create({

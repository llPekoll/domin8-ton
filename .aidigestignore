                Disconnect
              </button>
            </div>
          </div>
        )}
      </div>
      </>
    );
  }

  return (
    <>
      <WithdrawDialog isOpen={showWithdrawDialog} onClose={() => setShowWithdrawDialog(false)} />
      <div className={`relative ${className}`} ref={dropdownRef}>

import { IRefPhaserGame, PhaserGame } from "./PhaserGame";
import { Header } from "./components/Header";
import { CharacterSelection2 } from "./components/CharacterSelection2";
import { BettingPanel } from "./components/BettingPanel";
import { BlockchainDebugDialog } from "./components/BlockchainDebugDialog";
import { MultiParticipantPanel } from "./components/MultiParticipantPanel";
import { useGameContext } from "./contexts/GameContext";
import { useGameState } from "./hooks/useGameState";
import { useSharedSubscription } from "./hooks/useSharedSubscription";
import { useAutoCreatePlayer } from "./hooks/useAutoCreatePlayer";
import { logger } from "./lib/logger";
import { usePrivyWallet } from "./hooks/usePrivyWallet";
import { useQuery } from "convex/react";
import { api } from "../convex/_generated/api";
// ADD THIS IMPORT
import { ConnectWalletDialog } from "./components/ConnectWalletDialog";

function App() {
  const phaserRef = useRef<IRefPhaserGame | null>(null);
  const { selectedCharacter, setSelectedCharacter } = useGameContext();
  const { publicKey, ready: walletReady, externalWalletAddress } = usePrivyWallet();

  // ADD THIS STATE
  const [showConnectDialog, setShowConnectDialog] = useState(false);

  const connected = !!publicKey;
  const walletAddress = publicKey ? publicKey.toString() : null;

  useSharedSubscription(walletAddress);
  useAutoCreatePlayer(connected, walletAddress, externalWalletAddress);

  const { gameState, gameConfig, vaultBalance, loading, error, refresh } = useGameState();
  const playerData = useQuery(
    api.players.getPlayerWithCharacter,
    connected && walletAddress ? { walletAddress } : "skip"
  );

  const selectedCharacterId = useMemo(() => {
    if (selectedCharacter) {
      return selectedCharacter.id;
    }
    if (playerData?.character) {
      return playerData.character.id;
    }
    return 1;
  }, [selectedCharacter, playerData]);

  useEffect(() => {
    if (playerData?.character && !selectedCharacter) {
      setSelectedCharacter(playerData.character);
    }
  }, [playerData, selectedCharacter, setSelectedCharacter]);

  useEffect(() => {
    logger.ui.debug("[App.tsx] Main effect triggered", {
      connected,
      walletAddress,
      selectedCharacterId,
      hasPlayerData: !!playerData,
      isLoading: loading,
      gameState: gameState?.status,
    });
  }, [connected, walletAddress, selectedCharacterId, playerData, loading, gameState]);

  // ADD THIS EFFECT TO SHOW DIALOG WHEN NOT CONNECTED
  useEffect(() => {
    // Wait for wallet to be ready before showing dialog
    if (!walletReady) return;

    // Show dialog if user is not connected
    if (!connected) {
      // Optional: Add a small delay so it doesn't appear too abruptly
      const timer = setTimeout(() => {
        setShowConnectDialog(true);
      }, 500);

      return () => clearTimeout(timer);
    }
  }, [walletReady, connected]);

  return (
    <div className="flex flex-col h-screen overflow-hidden">
      <Header
        onRefreshGame={refresh}
        gameState={gameState}
        gameConfig={gameConfig}
        vaultBalance={vaultBalance}
        isLoading={loading}
        error={error}
      />

      <div className="flex-1 flex items-center justify-center overflow-hidden relative">
        <PhaserGame ref={phaserRef} currentActiveScene={undefined} />

        <CharacterSelection2
          onCharacterChange={setSelectedCharacter}
          defaultCharacterId={selectedCharacterId}
        />

        <MultiParticipantPanel />

        <BettingPanel
          walletAddress={walletAddress}
          connected={connected}
          selectedCharacter={selectedCharacter}
          onRefreshGame={refresh}
        />

        <BlockchainDebugDialog />
      </div>

      {/* ADD THIS COMPONENT */}
      <ConnectWalletDialog
        open={showConnectDialog}
        onOpenChange={setShowConnectDialog}
      />
    </div>
  );
}

export default App;

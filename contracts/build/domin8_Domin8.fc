}

((slice, slice, int, int, int, int, int, int, int), slice) $Domin8$_fun_owner((slice, slice, int, int, int, int, int, int, int) $self) impure inline_ref {
    var (($self'owner, $self'treasury, $self'houseFee, $self'minBet, $self'maxBet, $self'roundTime, $self'currentRound, $self'lobbyCount, $self'locked)) = $self;
    var $fresh$ret_41 = $self'owner;
    return (($self'owner, $self'treasury, $self'houseFee, $self'minBet, $self'maxBet, $self'roundTime, $self'currentRound, $self'lobbyCount, $self'locked), $fresh$ret_41);

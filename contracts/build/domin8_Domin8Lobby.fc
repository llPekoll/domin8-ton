;;
;; Routing of a Contract Domin8Lobby
;;

;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'parent, $self'lobbyId, $self'configured, $self'playerA, $self'playerB, $self'amount, $self'houseFee, $self'mapId, $self'skinA, $self'skinB, $self'commitHash, $self'status, $self'winner, $self'createdAt) = $Domin8Lobby$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) { return (); }
    var op = in_msg~load_opcode_internal();
    ;; Receive SetLobbyConfig message
    if (op == 2415301961) {
        var $msg'playerA = in_msg~load_msg_addr();
        var $msg'amount = in_msg~load_varuint16();
        var $msg'houseFee = in_msg~load_uint(16);
        var $msg'mapId = in_msg~load_uint(8);
        var $msg'skinA = in_msg~load_uint(8);
        var $msg'commitHash = in_msg~load_uint(256);
        throw_unless(34262, ( equal_slices_bits(__tact_context_get_sender(), $self'parent) ));
        throw_unless(20796, (~ $self'configured));
        $self'playerA = $msg'playerA;
        $self'amount = $msg'amount;
        $self'houseFee = $msg'houseFee;
        $self'mapId = $msg'mapId;
        $self'skinA = $msg'skinA;
        $self'commitHash = $msg'commitHash;
        $self'createdAt = $global_now();
        $self'configured = true;
        $Domin8Lobby$_contract_store(($self'parent, $self'lobbyId, $self'configured, $self'playerA, $self'playerB, $self'amount, $self'houseFee, $self'mapId, $self'skinA, $self'skinB, $self'commitHash, $self'status, $self'winner, $self'createdAt));
        return ();
    }
    
    ;; Receive JoinLobby message
    if (op == 4223482501) {
        var $msg'skin = in_msg~load_uint(8);
        throw_unless(41450, $self'configured);
        var ($ctx'bounceable, $ctx'sender, $ctx'value, $ctx'raw) = __tact_context_get();
        throw_unless(2537, ($self'status == 0));
        throw_unless(6698, ( ~ equal_slices_bits($ctx'sender, $self'playerA) ));
        int $gasReserve = 50000000;
        int $betAmount = ($ctx'value - $gasReserve);
        throw_unless(9306, ($betAmount >= $self'amount));
        $self'playerB = $ctx'sender;
        $self'skinB = $msg'skin;
        $self'status = 1;
        int $excess = ($betAmount - $self'amount);
        if (($excess > 1000000)) {
            $global_send($SendParameters$_constructor_to_value_mode_body($ctx'sender, $excess, 1, __gen_cell_cell_c1c75eb884c9645193f2b58323ece7de629f4b631731640616f0fe82d137d2ed()));
        }
        $Domin8Lobby$_contract_store(($self'parent, $self'lobbyId, $self'configured, $self'playerA, $self'playerB, $self'amount, $self'houseFee, $self'mapId, $self'skinA, $self'skinB, $self'commitHash, $self'status, $self'winner, $self'createdAt));
        return ();
    }
    
    ;; Receive SettleLobby message
    if (op == 1018103688) {
        var $msg'lobbyId = in_msg~load_uint(64);
        var $msg'secret = in_msg~load_uint(256);
        throw_unless(34262, ( equal_slices_bits(__tact_context_get_sender(), $self'parent) ));
        throw_unless(40356, ($self'status == 1));
        throw_unless(33511, (~ null?($self'playerB)));
        int $hash = ($self'parent, $self'lobbyId, $self'configured, $self'playerA, $self'playerB, $self'amount, $self'houseFee, $self'mapId, $self'skinA, $self'skinB, $self'commitHash, $self'status, $self'winner, $self'createdAt)~$Domin8Lobby$_fun_computeHash($msg'secret);
        throw_unless(13204, ($hash == $self'commitHash));
        $self'status = 2;
        ifnot (($msg'secret % 2)) {
            $self'winner = $self'playerA;
        } else {
            $self'winner = $self'playerB;
        }
        int $totalPot = ($self'amount * 2);
        int $fee = (($totalPot * $self'houseFee) / 10000);
        int $prize = ($totalPot - $fee);
        $global_send($SendParameters$_constructor_to_value_mode_body(__tact_not_null($self'winner), $prize, 1, __gen_cell_cell_cd0c07604bdab670db8667db1699e44f9081a03d5ec5447633036dd784780e85()));
        $global_send($SendParameters$_constructor_to_value_mode_body($self'parent, 0, 160, $InternalLobbySettled$_store_cell($InternalLobbySettled$_constructor_lobbyId_winner_prize_fee($self'lobbyId, __tact_not_null($self'winner), $prize, $fee), begin_cell())));
        $Domin8Lobby$_contract_store(($self'parent, $self'lobbyId, $self'configured, $self'playerA, $self'playerB, $self'amount, $self'houseFee, $self'mapId, $self'skinA, $self'skinB, $self'commitHash, $self'status, $self'winner, $self'createdAt));
        return ();
    }
    
    ;; Receive RescueLobby message
    if (op == 680795721) {
        var $msg'lobbyId = in_msg~load_uint(64);
        throw_unless(34262, ( equal_slices_bits(__tact_context_get_sender(), $self'parent) ));
        if (($self'status == 1)) {
            throw_unless(4134, (($global_now() - $self'createdAt) > 3600));
        }
        $global_send($SendParameters$_constructor_to_value_mode_body($self'playerA, $self'amount, 1, __gen_cell_cell_73cc63e7c356e26074f0ebda69a9c9185fb7800f91f62bc094ce49e050523850()));
        if ((~ null?($self'playerB))) {
            $global_send($SendParameters$_constructor_to_value_mode_body(__tact_not_null($self'playerB), $self'amount, 1, __gen_cell_cell_73cc63e7c356e26074f0ebda69a9c9185fb7800f91f62bc094ce49e050523850()));
        }
        $global_send($SendParameters$_constructor_to_value_mode_body($self'parent, 0, 160, $InternalUnlock$_store_cell($InternalUnlock$_constructor_(), begin_cell())));
        $Domin8Lobby$_contract_store(($self'parent, $self'lobbyId, $self'configured, $self'playerA, $self'playerB, $self'amount, $self'houseFee, $self'mapId, $self'skinA, $self'skinB, $self'commitHash, $self'status, $self'winner, $self'createdAt));
        return ();
    }
    
    ;; Receive Deploy message
    if (op == 0x946a98b6) {
        var $deploy'queryId = in_msg~load_uint(64);
        ($self'parent, $self'lobbyId, $self'configured, $self'playerA, $self'playerB, $self'amount, $self'houseFee, $self'mapId, $self'skinA, $self'skinB, $self'commitHash, $self'status, $self'winner, $self'createdAt)~$Domin8Lobby$_fun_notify($DeployOk$_store_cell($DeployOk$_constructor_queryId($deploy'queryId), begin_cell()));
        $Domin8Lobby$_contract_store(($self'parent, $self'lobbyId, $self'configured, $self'playerA, $self'playerB, $self'amount, $self'houseFee, $self'mapId, $self'skinA, $self'skinB, $self'commitHash, $self'status, $self'winner, $self'createdAt));
        return ();
    }
    
    ;; Throw if not handled
    throw(130);
}


() __tact_selector_hack_asm() impure asm """
@atend @ 1 {
        execute current@ context@ current!
        {
            // The core idea of this function is to save gas by avoiding unnecessary dict jump, when recv_internal/recv_external is called
            // We want to extract recv_internal/recv_external from the dict and select needed function
            // not by jumping to the needed function by it's index, but by using usual IF statements.

            }END> b> // Close previous builder, now we have a cell of previous code on top of the stack

            <{ // Start of the new code builder
                SETCP0
                // Swap the new code builder with the previous code, now we have previous code on top of the stack
                swap
                // Transform cell to slice and load first ref from the previous code, now we have the dict on top of the stack
                <s ref@

                // Extract the recv_internal from the dict
                dup 0 swap @procdictkeylen idict@ { "internal shortcut error" abort } ifnot
                swap

                // Delete the recv_internal from the dict
                0 swap @procdictkeylen idict- drop
                // Delete the recv_external from the dict (it's okay if it's not there)
                -1 swap @procdictkeylen idict- drop
                // Delete the __tact_selector_hack from the dict
                65535 swap @procdictkeylen idict- drop

                // Bring the code builder from the bottom of the stack
                // because if recv_external extraction is optional, and the number of elements on the stack is not fixed
                depth 1- roll
                // Swap with the dict from which we extracted recv_internal and (maybe) recv_external
                swap

                // Check if the dict is empty
                dup null?
                // Store a copy of this flag in the bottom of the stack
                dup depth 1- -roll
                {
                    // If the dict is empty, just drop it (it will be null if it's empty)
                    drop
                }
                {
                    // If the dict is not empty, prepare continuation to be stored in c3
                    <{
                        // Save this dict as first ref in this continuation, it will be pushed in runtime by DICTPUSHCONST
                        swap @procdictkeylen DICTPUSHCONST
                        // Jump to the needed function by it's index
                        DICTIGETJMPZ
                        // If such key is not found, throw 11 along with the key as an argument
                        11 THROWARG
                    }> PUSHCONT
                    // Store the continuation in c3
                    c3 POP
                } cond

                // Function id is on top of the (runtime) stack
                DUP IFNOTJMP:<{
                    // place recv_internal here
                    DROP swap @addop
                }>

                // Bring back the flag, indicating if the dict is empty or not from the bottom of the stack
                depth 1- roll
                {
                    // If the dict is empty, throw 11
                    11 THROWARG
                }
                {
                    // If the dict is not empty, jump to continuation from c3
                    c3 PUSH JMPX
                } cond
            }> b>
        } : }END>c
        current@ context! current!
    } does @atend !
""";

() __tact_selector_hack() method_id(65535) {
    return __tact_selector_hack_asm();
}
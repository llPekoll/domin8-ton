    return (($self'parent, $self'lobbyId, $self'configured, $self'playerA, $self'playerB, $self'amount, $self'houseFee, $self'mapId, $self'skinA, $self'skinB, $self'commitHash, $self'status, $self'winner, $self'createdAt), $fresh$ret_20);
}


{
  "name": "domin8-ton-contracts",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "tact --config tact.config.json",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "gen:wallet": "bun --env-file=.env scripts/gen-wallet.ts",
    "balance": "bun --env-file=.env scripts/balance.ts",
    "deploy:testnet": "bun --env-file=.env scripts/deploy.ts --network testnet",
    "deploy:mainnet": "bun --env-file=.env scripts/deploy.ts --network mainnet"
  },
  "dependencies": {
    "@ton/core": "^0.59.0",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^15.2.1"
  },
  "devDependencies": {
    "@tact-lang/compiler": "^1.6.13",
    "@ton/sandbox": "^0.23.0",
    "@ton/test-utils": "^0.7.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
